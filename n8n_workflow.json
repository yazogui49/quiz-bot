        "jsCode": "const questionRow = $input.first().json;\nconst ctx = $('Merge: userId (Answer)').first().json;\nconst wasCorrect = ctx.answer === questionRow.correct_answer;\nreturn [{ json: { ...ctx, correctAnswer: questionRow.correct_answer, wasCorrect } }];\n"
      },
