{
  "name": "Telegram Quiz Bot",
  "nodes": [
    {
      "parameters": {
        "updates": ["message", "callback_query"]
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [0, 300],
      "webhookId": "quiz-bot-webhook",
      "credentials": {
        "telegramApi": { "id": "TELEGRAM_CREDENTIAL_ID", "name": "Telegram Bot" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Route incoming update to the correct branch\nconst update = $input.first().json;\n\nlet type = 'unknown';\nlet telegramUserId = null;\nlet firstName = null;\nlet callbackData = null;\nlet callbackQueryId = null;\nlet chatId = null;\n\nif (update.callback_query) {\n  const cq = update.callback_query;\n  telegramUserId = cq.from.id;\n  firstName = cq.from.first_name;\n  chatId = cq.message.chat.id;\n  callbackQueryId = cq.id;\n  callbackData = cq.data;\n\n  if (callbackData === 'restart') {\n    type = 'restart';\n  } else if (callbackData && callbackData.startsWith('flag_')) {\n    type = 'flag';\n  } else if (['1','2','3','4'].includes(callbackData)) {\n    type = 'answer';\n  }\n} else if (update.message) {\n  const msg = update.message;\n  telegramUserId = msg.from.id;\n  firstName = msg.from.first_name;\n  chatId = msg.chat.id;\n  const text = (msg.text || '').trim();\n  if (text === '/start' || text === 'התחל לשחק' || text === '') {\n    type = 'start';\n  } else {\n    type = 'start'; // treat any plain text as /start for v1\n  }\n}\n\nreturn [{\n  json: {\n    type,\n    telegramUserId,\n    firstName,\n    chatId,\n    callbackData,\n    callbackQueryId\n  }\n}];\n"
      },
      "id": "route-update",
      "name": "Route Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.type }}", "rightValue": "start", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.type }}", "rightValue": "answer", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.type }}", "rightValue": "flag", "operator": { "type": "string", "operation": "equals" } }] } },
            { "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" }, "combinator": "and", "conditions": [{ "leftValue": "={{ $json.type }}", "rightValue": "restart", "operator": { "type": "string", "operation": "equals" } }] } }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "switch-type",
      "name": "Switch: Update Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [440, 300]
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO users (telegram_user_id, name)\nVALUES ({{ $json.telegramUserId }}, '{{ $json.firstName.replace(/'/g, \"''\") }}')\nON CONFLICT (telegram_user_id) DO UPDATE SET name = EXCLUDED.name\nRETURNING id, telegram_user_id, name;",
        "options": {}
      },
      "id": "upsert-user-start",
      "name": "Upsert User (Start)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [700, 100],
      "credentials": {
        "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Supabase Postgres" }
      }
    },
    {
      "parameters": {
        "jsCode": "const user = $input.first().json;\nconst routeData = $('Route Update').first().json;\nreturn [{ json: { ...routeData, userId: user.id } }];\n"
      },
      "id": "merge-start",
      "name": "Merge: userId (Start)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 100]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT q.*\nFROM questions q\nWHERE q.id NOT IN (\n  SELECT question_id FROM answers_log WHERE user_id = {{ $json.userId }}\n)\nORDER BY RANDOM()\nLIMIT 1;",
        "options": {}
      },
      "id": "fetch-question-start",
      "name": "Fetch Next Question (Start)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1140, 100],
      "credentials": {
        "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Supabase Postgres" }
      }
    },
    {
      "parameters": {
        "jsCode": "const question = $input.first().json;\nconst ctx = $('Merge: userId (Start)').first().json;\n\nif (!question || !question.id) {\n  return [{ json: { ...ctx, questionFound: false } }];\n}\nreturn [{ json: { ...ctx, questionFound: true, question } }];\n"
      },
      "id": "check-question-start",
      "name": "Check Question Found (Start)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 100]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "combinator": "and",
          "conditions": [{ "leftValue": "={{ $json.questionFound }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true" } }]
        }
      },
      "id": "if-found-start",
      "name": "Question Found? (Start)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1580, 100]
    },
    {
      "parameters": {
        "jsCode": "const { chatId, question } = $json;\nconst q = question;\n\nconst text =\n  `*${q.question}*\\n\\n` +\n  `1\\. ${q.option_a}\\n` +\n  `2\\. ${q.option_b}\\n` +\n  `3\\. ${q.option_c}\\n` +\n  `4\\. ${q.option_d}\\n\\n` +\n  `מה התשובה הכי נכונה?`;\n\nconst inline_keyboard = [\n  [\n    { text: '1', callback_data: `1|${q.id}` },\n    { text: '2', callback_data: `2|${q.id}` },\n    { text: '3', callback_data: `3|${q.id}` },\n    { text: '4', callback_data: `4|${q.id}` }\n  ],\n  [\n    { text: 'סמן כשאלה לא ברורה', callback_data: `flag_${q.id}` }\n  ]\n];\n\nreturn [{\n  json: {\n    chatId,\n    text,\n    reply_markup: JSON.stringify({ inline_keyboard })\n  }\n}];\n"
      },
      "id": "build-question-msg",
      "name": "Build Question Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 60]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "={{ $json.text }}",
        "additionalFields": {
          "parse_mode": "MarkdownV2",
          "reply_markup": "={{ $json.reply_markup }}"
        }
      },
      "id": "send-question-start",
      "name": "Send Question (Start)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2020, 60],
      "credentials": {
        "telegramApi": { "id": "TELEGRAM_CREDENTIAL_ID", "name": "Telegram Bot" }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "🎉 כל הכבוד! סיימת את כל השאלות.\\nלחץ כדי להתחיל מחדש:",
        "additionalFields": {
          "reply_markup": "{\"inline_keyboard\":[[{\"text\":\"התחל מחדש 🔄\",\"callback_data\":\"restart\"}]]}"
        }
      },
      "id": "send-done-start",
      "name": "Send Done Message (Start)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1800, 180],
      "credentials": {
        "telegramApi": { "id": "TELEGRAM_CREDENTIAL_ID", "name": "Telegram Bot" }
      }
    },

    {
      "parameters": {
        "jsCode": "// Parse callback_data format: \"<answer>|<questionId>\"\nconst routeData = $json;\nconst parts = (routeData.callbackData || '').split('|');\nconst answer = parts[0];\nconst questionId = parseInt(parts[1], 10);\nreturn [{ json: { ...routeData, answer, questionId } }];\n"
      },
