    {
      "parameters": {
        "jsCode": "const ctx = $('Evaluate Answer').first().json;\nconst feedbackText = ctx.wasCorrect\n  ? '✅ נכון! כל הכבוד!'\n  : `❌ לא נכון. התשובה הנכונה היא ${ctx.correctAnswer}.`;\nreturn [{ json: { ...ctx, feedbackText } }];\n"
